ASSEMBLING_SLA_HOURS=72
AUTO_APPROVE_PRODUCERS=True
# Sandbox providers: OAuth/оплата/доставка работают без реальных ключей.
# Для боевого режима выставить False и заполнить ключи ниже.
USE_SANDBOX_PROVIDERS=False

# ---- Redis (опционально; по умолчанию локальный кэш в памяти) ----
